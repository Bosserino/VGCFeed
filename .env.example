# Copia questo file in ".env" e riempi i valori (per i test in LOCALE).
# Su GitHub questi valori arrivano dai repository Secrets, NON da qui.
# .env e' in .gitignore: non finisce mai nel repo.

TELEGRAM_TOKEN=123456:ABC-il-tuo-token-da-BotFather
TELEGRAM_CHAT_ID=@iltuocanale
X_USERNAME=account_usa_e_getta
X_COOKIES=auth_token=XXXX; ct0=YYYY
GROQ_API_KEY=gsk_la_tua_chiave_groq

# --- opzionali ---
# GEMINI_API_KEY=la_tua_chiave_gemini   # fallback se Groq non risponde
# GROQ_MODEL=qwen/qwen3.6-27b           # override modello Groq
# GEMINI_MODEL=gemini-2.5-flash-lite    # override modello Gemini
# DRY_RUN=1                             # test: non invia e non salva lo stato
